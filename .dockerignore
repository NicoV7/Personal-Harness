# Build hygiene — keep the build context small and reproducible.
# Never bake host-only state into the image.

.git
.gitignore

# Claude Code/agent state — not part of the server.
.claude

# Local BetterAI state (corpus, audit, embeddings) — mounted at runtime.
.betterai
.betterai-dev

# Retired TypeScript tree and legacy JS tooling output — never in the image.
src
node_modules
dist
*.tsbuildinfo

# Docs, corpus authoring copies, and eval output — not consumed by the server.
docs
seed-corpus
skills
memories
eval-output

# Editor/OS noise.
.DS_Store
*.log
.env
.env.*
!.env.example

# Tests, fixtures, and Python caches don't ship in the runtime image.
tests
__pycache__
**/__pycache__
*.pyc
.pytest_cache
.venv

# Worktrees and IDE settings.
.idea
.vscode
