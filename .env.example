# BetterAI server environment (Python harness).
#
# Source of truth: app/settings.py (REQUIRED_KEYS — every key below is
# mandatory unless marked optional; there are NO runtime defaults, missing
# keys fail boot with BAI-120). Copy to `.env` (gitignored) for host-mode
# development (`python -m app.main` against local redis/postgres). The
# INSTALLED runtime never reads this file: `betterai install` mints
# ~/.betterai/.env with container paths (app/installer/install_env.py).

# --- Corpus + audit -------------------------------------------------------
# Corpus root the server reads (rules/ and skills/ live under it).
# Host dev: the repo checkout. Container: /data (bind-mounted ~/.betterai).
BETTERAI_CORPUS_ROOT=.
# Append-only JSONL audit log. Must be a file path, not a directory.
BETTERAI_AUDIT_PATH=./.betterai-dev/audit/audit.jsonl

# --- Transport + auth -----------------------------------------------------
BETTERAI_BIND_HOST=127.0.0.1
BETTERAI_MCP_PORT=7777
# Bearer token file; create with: openssl rand -hex 32 > .betterai-dev/token
BETTERAI_TOKEN_PATH=./.betterai-dev/token
# Optional: host:port allowlist for the DNS-rebinding check.
# BETTERAI_ALLOWED_HOSTS=127.0.0.1:7777,localhost:7777

# --- Stack ----------------------------------------------------------------
# redis >= 8.4 (FT.HYBRID) and pgvector-enabled postgres.
BETTERAI_REDIS_URL=redis://127.0.0.1:6379
BETTERAI_POSTGRES_DSN=postgresql://betterai:pw@127.0.0.1:5432/betterai
# BETTERAI_POSTGRES_PASSWORD is NOT read by the server — the installer
# generates it purely for docker-compose interpolation of the DSN above.
BETTERAI_COMPOSE_FILE=./.betterai-dev/docker-compose.yml
BETTERAI_DOCKER_SOCK=/var/run/docker.sock

# --- OpenRouter provider --------------------------------------------------
BETTERAI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Key lives in a file (never inline in env): file containing only the key.
BETTERAI_OPENROUTER_API_KEY_FILE=./.betterai-dev/openrouter-key
BETTERAI_OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Judge/distiller/classifier model (also the prompt-improver fallback).
BETTERAI_OPENROUTER_AGENT_MODEL=openai/gpt-5.2
# Prompt-expansion model for UserPromptSubmit retrieval; "off" disables.
BETTERAI_PROMPT_IMPROVER_MODEL=off

# --- Retrieval ------------------------------------------------------------
# Must match the embedding model's output dimension (text-embedding-3-small = 1536).
BETTERAI_EMBEDDING_DIM=1536
# Hybrid fusion: rrf | linear (linear also uses BETTERAI_HYBRID_ALPHA).
BETTERAI_HYBRID_FUSION=rrf
BETTERAI_HYBRID_ALPHA=0.7
# Cosine floor for selection; keyword hit is ALSO required (search.py).
BETTERAI_SIMILARITY_THRESHOLD=0.35
BETTERAI_MAX_CANDIDATES=100

# --- Harness behavior -----------------------------------------------------
# Edit-budget gate granularity: function | file | none.
BETTERAI_EDIT_GRANULARITY=none
# Memory provider service: basic-memory | cognee | none.
BETTERAI_MEMORY_PROVIDER=none
# Glob the plan-manifest gate uses to find plan files.
BETTERAI_PLAN_GLOB=**/.claude/plans/*.md
# Comment verbosity seed when the concise-comments skill is unconfigured:
# default | none | tokens:<int> | lines:<int>   (e.g. lines:2)
BETTERAI_COMMENT_VERBOSITY=default
# Read gate: on | off — off disables ONLY the mutating-tool deny (explicit escape hatch).
BETTERAI_READ_GATE=on
# Max skills served + required per prompt (forced first, then by score).
BETTERAI_REQUIRED_READS_MAX=5
