# BetterAI server environment configuration.
#
# Copy to `.env` (gitignored) and edit. Values here are the documented
# defaults from src/contracts/env.ts — the single source of truth. The
# entrypoint (src/index.ts) loads `.env` at startup but NEVER overrides a
# variable already set in the real environment, so docker/prod env always wins.

# Root of the corpus the server reads (rules/skills/memories live under it).
BETTERAI_CORPUS_ROOT=/data

# Append-only JSONL audit log path. Must point at a FILE, not a directory.
BETTERAI_AUDIT_PATH=/data/audit/audit.jsonl

# Read-only mount where host project repos are reachable inside the container.
BETTERAI_PROJECTS_ROOT=/projects

# TCP port the MCP Streamable-HTTP transport binds.
BETTERAI_MCP_PORT=7777

# Path to the bearer token file (the install script writes it before startup).
BETTERAI_TOKEN_PATH=/data/token

# Log verbosity: trace | debug | info | warn | error.
BETTERAI_LOG_LEVEL=info

# Interface to bind. 127.0.0.1 keeps the server loopback-only (recommended).
BETTERAI_BIND_HOST=127.0.0.1

# Optional comma-separated host:port allowlist override for the bearer
# middleware's DNS-rebinding check. Unset = derived from BIND_HOST:MCP_PORT
# plus the localhost:<port> alias when binding loopback.
# BETTERAI_ALLOWED_HOSTS=127.0.0.1:7777,localhost:7777

# RetrievalScorer implementation: grep | embedding | hybrid.
BETTERAI_RETRIEVAL_MODE=hybrid

# Directory holding the baked MiniLM model files (Phase 1.5 embeddings).
BETTERAI_MODEL_CACHE_DIR=/data/embeddings/models
